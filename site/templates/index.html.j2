<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MorningSignal Research — Daily Market Intelligence</title>
  <meta name="description" content="Professional market intelligence, breakout scanning, weekly strategy, podcast synthesis, and earnings briefs in one research hub.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=IBM+Plex+Mono:wght@400;500;600&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="assets/style.css">
  <link rel="icon" href="assets/logo.svg" type="image/svg+xml">
</head>
<body>

<header>
  <div class="header-inner">
    <a href="index.html" class="logo">
      <img src="assets/logo.svg" width="32" height="32" alt="MorningSignal">
      <div>
        <div class="logo-text">Morning<span>Signal</span></div>
        <div class="logo-sub">Research Platform</div>
      </div>
    </a>
    <nav>
      <a href="index.html" class="active">Home</a>
      <a href="daily/{{ today }}.html">Today</a>
      <a href="dashboard.html">Dashboard</a>
      <a href="industries.html">Industries</a>
      <a href="investordebate.html">Debate</a>
      <a href="weekly.html">Weekly</a>
      <a href="podcast.html">Podcast</a>
      <a href="earnings.html">Earnings</a>
      <a href="archive.html">Archive</a>
    </nav>
    <div class="header-date">{{ generated_at }}</div>
  </div>
</header>

{% set narrative = brief.get('narrative', {}) if brief.get('narrative') is mapping else {} %}
{% set spx = brief.indices.get('SPY', {}) %}
{% set qqq = brief.indices.get('QQQ', {}) %}
{% set market_up = spx.get('day_change', 0) >= 0 %}
{% set signal = brief.get('market_signal', {}) %}
{% set narrative_source = narrative.get('source', 'ai') %}

<div class="hero-strip">
  <div class="page-wrapper">
    <div class="hero-panel hero-panel-main">
      <div class="hero-copy">
        <div class="eyebrow">Automated Market Intelligence</div>
        <div class="hero-title">MorningSignal Research</div>
        <div class="hero-summary">
          {{ narrative.get('summary', 'A daily market intelligence hub combining systematic scans, macro context, earnings monitoring, and podcast synthesis.') }}
        </div>
        <div class="hero-meta-row">
          <span class="hero-market-badge {{ 'hero-badge-up' if market_up else 'hero-badge-down' }}">
            S&amp;P {{ "%+.2f"|format(spx.get('day_change', 0)) }}%
          </span>
          <span class="pill">QQQ {{ "%+.2f"|format(qqq.get('day_change', 0)) }}%</span>
          <span class="pill">{{ today }}</span>
        </div>
        <div class="hero-actions">
          <a href="daily/{{ today }}.html" class="button button-primary">Open Daily Report</a>
          <a href="weekly.html" class="button button-secondary">Read Weekly Note</a>
        </div>
      </div>

      <div class="hero-aside">
        <div class="hero-metric-grid">
          <div class="hero-mini-card">
            <div class="hero-mini-label">Market Signal</div>
            <div class="hero-mini-value">{{ signal.get('signal', 'N/A') }}</div>
            <div class="hero-mini-meta">Score {{ "%.2f"|format(signal.get('score', 0)) }}</div>
          </div>
          <div class="hero-mini-card">
            <div class="hero-mini-label">Tape Source</div>
            <div class="hero-mini-value">{{ 'Fallback' if narrative_source == 'fallback' else 'GPT-5.4' }}</div>
            <div class="hero-mini-meta">{{ 'Data-derived commentary' if narrative_source == 'fallback' else 'OpenAI-generated narrative' }}</div>
          </div>
          <div class="hero-mini-card">
            <div class="hero-mini-label">Breakout Scan</div>
            <div class="hero-mini-value">{{ breakouts|length }}</div>
            <div class="hero-mini-meta">Setups passing the model today</div>
          </div>
          <div class="hero-mini-card">
            <div class="hero-mini-label">Platform</div>
            <div class="hero-mini-value">Daily · Weekly</div>
            <div class="hero-mini-meta">Podcast and earnings feeds included</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-wrapper">

  <div class="section">
    <div class="section-head">
      <div>
        <div class="section-kicker">At A Glance</div>
        <div class="section-title">Market Snapshot</div>
      </div>
      <div class="section-note">Core index performance and year-to-date context.</div>
    </div>
    <div class="card-grid card-grid-4">
      {% for sym, idx in brief.indices.items() %}
      <div class="stat-card card">
        <div class="stat-label">{{ idx.name }}</div>
        <div class="stat-value">${{ "%.2f"|format(idx.price) }}</div>
        <div class="stat-meta">
          <span class="{{ 'pos' if idx.day_change >= 0 else 'neg' }}">{{ "%+.2f"|format(idx.day_change) }}% today</span>
          ·
          <span class="{{ 'pos' if idx.ytd_change >= 0 else 'neg' }}">{{ "%+.2f"|format(idx.ytd_change) }}% YTD</span>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="section">
    <div class="section-head">
      <div>
        <div class="section-kicker">Desk Read</div>
        <div class="section-title">Today's Tape</div>
      </div>
      <div class="section-note">Sector commentary generated from the day’s market data and headline set.</div>
    </div>
    {% if narrative.get('bullets') %}
      <div class="tape-summary">{{ narrative.get('summary', '') }}</div>
      <div class="tape-bullets">
        {% for bullet in narrative.get('bullets', []) %}
        <div class="tape-bullet {{ 'tape-bullet-up' if bullet.change >= 0 else 'tape-bullet-down' }}">
          <div class="tape-bullet-header">
            <span class="tape-bullet-sector">{{ bullet.sector }}</span>
            <span class="tape-bullet-change {{ 'pos' if bullet.change >= 0 else 'neg' }}">{{ "%+.1f"|format(bullet.change) }}%</span>
          </div>
          <div class="tape-bullet-text">{{ bullet.narrative }}</div>
        </div>
        {% endfor %}
      </div>
      {% if narrative.get('cross_sector') %}
      <div class="tape-cross-sector">
        <span class="tape-cross-label">Cross-Sector Linkage</span>
        <div class="hero-subtitle" style="margin-top:10px">{{ narrative.get('cross_sector') }}</div>
      </div>
      {% endif %}
      <div class="tape-meta">
        {{ 'Data-derived fallback commentary' if narrative_source == 'fallback' else 'GPT-5.4-generated market commentary' }} · Not financial advice
      </div>
    {% else %}
      <div class="note-card">Narrative commentary is unavailable for this date, but the rest of the market data and setup scan remain fully intact.</div>
    {% endif %}
  </div>

  <div class="two-col mt-24">
    <div class="section">
      <div class="section-title">Signal & Macro</div>
      {% if signal %}
      <div class="signal-card">
        <div class="signal-top">
          <div class="signal-badge signal-{{ signal.signal|lower|replace(' ', '-') }}">{{ signal.signal }}</div>
          <div class="signal-score">{{ "%.2f"|format(signal.score) }}</div>
        </div>
        <div class="signal-meter">
          <div class="signal-meter-track">
            <div class="signal-meter-marker" style="left: {{ ((signal.score + 1) / 2 * 100)|round }}%"></div>
          </div>
          <div class="signal-meter-labels">
            <span>Risk Off</span>
            <span>Neutral</span>
            <span>Risk On</span>
          </div>
        </div>
        <div class="signal-components">
          {% for name, comp in signal.components.items() %}
          <div class="signal-comp">
            <span class="signal-comp-name">{{ name }}</span>
            <span class="signal-comp-detail">{{ comp.detail }}</span>
            <span class="signal-comp-score {{ 'pos' if comp.score > 0 else ('neg' if comp.score < 0 else 'neu') }}">{{ "%+.2f"|format(comp.score) }}</span>
          </div>
          {% endfor %}
        </div>
        {% if narrative.get('signal_interpretation') %}
        <div class="signal-interp">{{ narrative.get('signal_interpretation') }}</div>
        {% endif %}
      </div>
      {% endif %}

      <div class="macro-grid mt-24">
        <div class="stat-card card">
          <div class="stat-label">VIX</div>
          <div class="stat-value">{{ "%.2f"|format(brief.macro.vix.level) }}</div>
          <div class="stat-meta">{{ "%+.2f"|format(brief.macro.vix['5d_change']) }}% over 5d</div>
        </div>
        <div class="stat-card card">
          <div class="stat-label">10Y Yield</div>
          <div class="stat-value">{{ "%.2f"|format(brief.macro.tnx.level) }}%</div>
          <div class="stat-meta">Treasury benchmark</div>
        </div>
        <div class="stat-card card">
          <div class="stat-label">2Y Yield</div>
          <div class="stat-value">{{ "%.2f"|format(brief.macro.irx.level) }}%</div>
          <div class="stat-meta">Front-end rate signal</div>
        </div>
        <div class="stat-card card">
          <div class="stat-label">2s/10s</div>
          {% set spread = brief.macro.spread_2s10s %}
          <div class="stat-value {{ 'pos' if spread >= 0 else 'neg' }}">{{ "%+.0f"|format(spread * 100) }}bps</div>
          <div class="stat-meta">{{ 'Steepening / normal' if spread >= 0 else 'Still inverted' }}</div>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="section-title">Participation</div>
      <div class="card">
        <div class="sector-list">
          {% set max_abs = namespace(val=0.01) %}
          {% for s in brief.sectors %}
            {% if s.day_change|abs > max_abs.val %}{% set max_abs.val = s.day_change|abs %}{% endif %}
          {% endfor %}
          {% for s in brief.sectors[:6] %}
          <div class="sector-row">
            <div class="sector-name">{{ s.name }}</div>
            <div class="sector-bar-wrap">
              {% set pct = (s.day_change / max_abs.val * 100)|abs %}
              <div class="sector-bar {{ 'pos-bar' if s.day_change >= 0 else 'neg-bar' }}" style="width:{{ pct }}%"></div>
            </div>
            <div class="sector-chg {{ 'pos' if s.day_change >= 0 else 'neg' }}">{{ "%+.2f"|format(s.day_change) }}%</div>
          </div>
          {% endfor %}
        </div>
      </div>

      {% if narrative.get('overnight') %}
      <div class="section">
        <div class="section-title">Overnight & Global</div>
        <div class="overnight-card">{{ narrative.get('overnight') }}</div>
      </div>
      {% endif %}
    </div>
  </div>

  <div class="section">
    <div class="section-head">
      <div>
        <div class="section-kicker">Leadership</div>
        <div class="section-title">High-Conviction Setups</div>
      </div>
      <a href="daily/{{ today }}.html" class="button button-secondary">View Full Scan</a>
    </div>
    <div class="breakout-table-wrap">
      <table class="breakout-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Ticker</th>
            <th>Name</th>
            <th>Sector</th>
            <th>Score</th>
            <th>RS</th>
            <th>Base</th>
            <th>Trend</th>
            <th>Price</th>
            <th>vs 52W High</th>
            <th>Vol/Avg</th>
          </tr>
        </thead>
        <tbody>
          {% for b in breakouts[:8] %}
          {% set sc = b.score %}
          <tr>
            <td class="rank-cell">{{ b.rank }}</td>
            <td class="ticker-cell">
              <a href="deep-dives/{{ b.ticker }}.html">{{ b.ticker }}</a>
              {% if b.get('streak_days', 1) >= 3 %}
              <span class="flag-badge" title="{{ b.streak_days }} consecutive days">★</span>
              {% endif %}
            </td>
            <td class="name-cell">{{ b.name }}</td>
            <td class="name-cell">{{ b.sector }}</td>
            <td>
              <div class="score-bar">
                <span class="score-cell {{ 's-high' if sc >= 80 else ('s-mid' if sc >= 60 else 's-low') }}">{{ "%.1f"|format(sc) }}</span>
                <div class="score-bar-bg">
                  <div class="score-bar-fill {{ '' if sc >= 80 else ('mid' if sc >= 60 else 'low') }}" style="width:{{ sc }}%"></div>
                </div>
              </div>
            </td>
            <td class="mono {{ 's-high' if b.rs >= 80 else ('s-mid' if b.rs >= 60 else 's-low') }}">{{ "%.1f"|format(b.rs) }}</td>
            <td class="mono">{{ "%.1f"|format(b.base) }}</td>
            <td class="mono">{{ "%.1f"|format(b.trend) }}</td>
            <td class="mono">${{ "%.2f"|format(b.price) }}</td>
            <td class="mono {{ 'neg' if b.pct_from_high < -10 else 'pos' }}">{{ "%+.1f"|format(b.pct_from_high) }}%</td>
            <td class="mono {{ 'pos' if b.vol_ratio >= 1.4 else '' }}">{{ "%.2f"|format(b.vol_ratio) }}x</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="section">
    <div class="section-head">
      <div>
        <div class="section-kicker">Coverage</div>
        <div class="section-title">Platform Modules</div>
      </div>
      <div class="section-note">The research stack now spans daily tape, weekly synthesis, podcast intelligence, and earnings coverage.</div>
    </div>
    <div class="link-grid">
      <a href="weekly.html" class="link-card">
        <h3>Weekly Strategy</h3>
        <p>Friday rollups that connect the week’s catalysts, sector rotations, and thematic positioning.</p>
      </a>
      <a href="podcast.html" class="link-card">
        <h3>Podcast Intelligence</h3>
        <p>Audio-ready synthesis from the podcast universe with transcripts available on-site.</p>
      </a>
      <a href="earnings.html" class="link-card">
        <h3>Earnings Briefs</h3>
        <p>Pre-market and post-close notes organized for quick scanning, follow-through, and watchlists.</p>
      </a>
    </div>
  </div>

</div>

<footer>
  <div>MorningSignal Research · Generated {{ generated_at }} · Commentary is for research purposes only and not investment advice.</div>
</footer>

</body>
</html>
